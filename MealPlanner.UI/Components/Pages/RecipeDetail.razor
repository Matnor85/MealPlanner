@page "/recipe/{Id:guid}"
@using Domain.Entities
@using Domain.Interfaces

@inject IRecipeRepository RecipeRepo
@inject IFoodItemRepository FoodRepo
@inject NavigationManager Nav

<button class="back-link" @onclick='() => Nav.NavigateTo("/recipes")'>‹ Recept</button>

@if (recipe is null)
{
    <p class="muted">Laddar...</p>
}
else
{
    <section class="day-header">
        <h1 class="day-title">@recipe.Name</h1>
        <div class="day-total">@recipe.CaloriesPerPortion <span class="unit">kcal/port.</span></div>
    </section>

    @if (errorMessage is not null)
    {
        <div class="banner-error">@errorMessage</div>
    }

    @if (!isEditing)
    {
        <button class="btn-primary" @onclick='() => Nav.NavigateTo($"/cook/{Id}")'>
            Laga den här rätten
        </button>
        <button class="btn-secondary" @onclick="StartEditing">Redigera receptet</button>
    }
    else
    {
        <div class="edit-banner">
            Redigeringsläge — ändringar sparas direkt.
            <button class="link-btn" @onclick="StopEditing">Klar</button>
        </div>

        <div class="add-card">
            <h2 class="add-title">Lägg till ingrediens</h2>

            <div class="field">
                <span>Råvara</span>
                <SearchPicker Items="foodItems"
                              @bind-SelectedId="newFoodId"
                              Placeholder="Sök råvara..." />
            </div>

            <label class="field">
                <span>Mängd i gram (för hela receptet)</span>
                <input type="number" min="1" @bind="newGrams" />
            </label>

            <button class="btn-primary" @onclick="AddIngredient"
                    disabled="@(!newFoodId.HasValue)">
                Lägg till
            </button>
        </div>
    }

    <div class="meal-group">
        <div class="meal-group-head">
            <span>Ingredienser</span>
            <span>@recipe.TotalCalories kcal totalt</span>
        </div>

        @if (recipe.Ingredients.Count == 0)
        {
            <div class="meal-row"><span class="muted">Inga ingredienser än.</span></div>
        }

        @foreach (var ing in recipe.Ingredients)
        {
            <div class="meal-row">
                <div>
                    <div class="meal-name">@(ing.Food?.Name ?? "Okänd")</div>
                    <div class="meal-sub">@ing.WeightInGrams g</div>
                </div>
                <div class="meal-right">
                    <span class="meal-kcal">@ing.CalculatedCalories</span>

                    @if (isEditing)
                    {
                        @if (pendingDeleteId == ing.Id)
                        {
                            <button class="confirm-btn" @onclick="() => RemoveIngredient(ing.Id)">
                                Ta bort?
                            </button>
                            <button class="link-btn" @onclick="() => pendingDeleteId = null">Nej</button>
                        }
                        else
                        {
                            <button class="del-btn" @onclick="() => pendingDeleteId = ing.Id"
                                    aria-label="Ta bort">
                                ×
                            </button>
                        }
                    }
                </div>
            </div>
        }
    </div>

    @if (recipe.Steps.Count > 0)
    {
        <div class="meal-group">
            <div class="meal-group-head">
                <span>Gör så här</span>
                <span>@recipe.TotalMinutes min</span>
            </div>
            @foreach (var s in recipe.Steps.OrderBy(s => s.StepNumber))
            {
                <div class="meal-row">
                    <div><span class="step-inline-num">@s.StepNumber.</span> @s.Text</div>
                </div>
            }
        </div>
    }

    @if (isEditing)
    {
        @if (confirmDeleteRecipe)
        {
            <div class="danger-confirm">
                Radera hela receptet? Det går inte att ångra.
                <div class="btn-row">
                    <button class="btn-secondary" @onclick="() => confirmDeleteRecipe = false">Avbryt</button>
                    <button class="btn-danger" @onclick="DeleteRecipe">Ja, radera</button>
                </div>
            </div>
        }
        else
        {
            <button class="btn-danger" @onclick="() => confirmDeleteRecipe = true">
                Radera receptet
            </button>
        }
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Recipe? recipe;
    private List<FoodItem> foods = new();
    private List<PickerItem> foodItems = new();
    private string? errorMessage;

    private bool isEditing;
    private Guid? pendingDeleteId;
    private bool confirmDeleteRecipe;

    private Guid? newFoodId;
    private int newGrams = 100;

    protected override async Task OnInitializedAsync()
    {
        foods = (await FoodRepo.GetAllAsync()).ToList();

        foodItems = foods
            .Select(f => new PickerItem(f.Id, f.Name, $"{f.CaloriesPer100g} kcal/100 g"))
            .ToList();

        await LoadAsync();
    }

    private async Task LoadAsync() => recipe = await RecipeRepo.GetByIdAsync(Id);

    private void StartEditing()
    {
        isEditing = true;
        errorMessage = null;
    }

    private void StopEditing()
    {
        isEditing = false;
        pendingDeleteId = null;
        confirmDeleteRecipe = false;
    }

    private async Task AddIngredient()
    {
        if (newFoodId is not Guid foodId) return;

        await RecipeRepo.AddIngredientAsync(new RecipeIngredient
        {
            RecipeId = Id,
            FoodId = foodId,
            WeightInGrams = newGrams
        });

        newFoodId = null;
        newGrams = 100;
        await LoadAsync();
    }

    private async Task RemoveIngredient(Guid ingredientId)
    {
        await RecipeRepo.RemoveIngredientAsync(ingredientId);
        pendingDeleteId = null;
        await LoadAsync();
    }

    private async Task DeleteRecipe()
    {
        try
        {
            await RecipeRepo.DeleteAsync(Id);
            Nav.NavigateTo("/recipes");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            confirmDeleteRecipe = false;
            await LoadAsync();
        }
    }
}