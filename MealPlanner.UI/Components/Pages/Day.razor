@page "/day/{Year:int}/{Week:int}/{Sort:int}"
@using Application.Services
@using Domain.Entities
@using Domain.Interfaces

@inject WeeklyPlannerService PlannerService
@inject IFoodItemRepository FoodRepo
@inject IRecipeRepository RecipeRepo
@inject NavigationManager Nav

<button class="back-link" @onclick="GoBack">‹ Vecka @Week</button>

@if (day is null)
{
    <p class="muted">Laddar...</p>
}
else
{
    <section class="day-header">
        <h1 class="day-title">@ToSwedish(day.Day)</h1>
        <div class="day-total">@day.TotalCalories <span class="unit">kcal</span></div>
    </section>

    @if (errorMessage is not null)
    {
        <div class="banner-error">@errorMessage</div>
    }

    <div class="add-card">
        <h2 class="add-title">Lägg till måltid</h2>

        <div class="segmented">
            <button class="seg @(useRecipe ? "" : "on")" @onclick="() => SwitchMode(false)">Råvara</button>
            <button class="seg @(useRecipe ? "on" : "")" @onclick="() => SwitchMode(true)">Recept</button>
        </div>

        <label class="field">
            <span>Måltid</span>
            <select @bind="newType">
                @foreach (var t in Enum.GetValues<MealType>())
                {
                    <option value="@t">@ToSwedish(t)</option>
                }
            </select>
        </label>

        @if (useRecipe)
        {
            @if (recipeItems.Count == 0)
            {
                <p class="muted">Du har inga recept än. <a href="recipes">Skapa ett först →</a></p>
            }
            else
            {
                <div class="field">
                    <span>Recept</span>
                    <SearchPicker Items="recipeItems"
                                  @bind-SelectedId="newRecipeId"
                                  Placeholder="Sök recept..." />
                </div>

                <label class="field">
                    <span>Antal portioner</span>
                    <input type="number" step="0.25" min="0.25" @bind="newPortions" />
                </label>
            }
        }
        else
        {
            <div class="field">
                <span>Råvara</span>
                <SearchPicker Items="foodItems"
                              @bind-SelectedId="newFoodId"
                              Placeholder="Sök råvara, t.ex. äpp..." />
            </div>

            <label class="field">
                <span>Vikt i gram</span>
                <input type="number" min="1" @bind="newGrams" />
            </label>
        }

        <div class="preview">≈ @PreviewCalories kcal</div>

        <button class="btn-primary" @onclick="Add" disabled="@(!CanAdd)">Lägg till</button>
    </div>

    @if (day.Meals.Count == 0)
    {
        <div class="stub">Inget planerat för den här dagen än.</div>
    }

    @foreach (var group in Enum.GetValues<MealType>())
    {
        var meals = day.Meals.Where(m => m.Type == group).ToList();
        if (meals.Count == 0) continue;

        <div class="meal-group">
            <div class="meal-group-head">
                <span>@ToSwedish(group)</span>
                <span>@meals.Sum(m => m.CalculatedCalories) kcal</span>
            </div>
            @foreach (var meal in meals)
            {
                <div class="meal-row">
                    <div>
                        <div class="meal-name">
                            @meal.DisplayName
                            @if (meal.IsRecipeMeal)
                            {
                                <span class="tag">recept</span>
                            }
                        </div>
                        <div class="meal-sub">@meal.DisplayAmount</div>
                    </div>
                    <div class="meal-right">
                        <span class="meal-kcal">@meal.CalculatedCalories</span>
                        <button class="del-btn" @onclick="() => Remove(meal.Id)" aria-label="Ta bort">×</button>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public int Year { get; set; }
    [Parameter] public int Week { get; set; }
    [Parameter] public int Sort { get; set; }

    private DailyPlan? day;
    private List<FoodItem> foods = new();
    private List<Recipe> recipes = new();
    private List<PickerItem> foodItems = new();
    private List<PickerItem> recipeItems = new();
    private string? errorMessage;

    private bool useRecipe;
    private MealType newType = MealType.Breakfast;
    private Guid? newFoodId;
    private int newGrams = 100;
    private Guid? newRecipeId;
    private double newPortions = 1;

    private bool CanAdd => useRecipe
        ? newRecipeId.HasValue && newPortions > 0
        : newFoodId.HasValue && newGrams > 0;

    private int PreviewCalories
    {
        get
        {
            if (useRecipe)
            {
                var r = recipes.FirstOrDefault(x => x.Id == newRecipeId);
                return r is null ? 0 : (int)Math.Round(r.CaloriesPerPortion * newPortions);
            }

            var f = foods.FirstOrDefault(x => x.Id == newFoodId);
            return f is null ? 0 : (int)Math.Round((double)f.CaloriesPer100g * newGrams / 100);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        foods = (await FoodRepo.GetAllAsync()).ToList();
        recipes = (await RecipeRepo.GetAllAsync()).ToList();

        foodItems = foods
            .Select(f => new PickerItem(f.Id, f.Name, $"{f.CaloriesPer100g} kcal/100 g"))
            .ToList();

        recipeItems = recipes
            .Select(r => new PickerItem(r.Id, r.Name, $"{r.CaloriesPerPortion} kcal/port."))
            .ToList();

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var week = await PlannerService.GetOrCreateWeekAsync(Year, Week);
        day = week.Days.FirstOrDefault(d => d.SortOrder == Sort);
    }

    private void SwitchMode(bool recipeMode)
    {
        useRecipe = recipeMode;
        newFoodId = null;
        newRecipeId = null;
    }

    private async Task Add()
    {
        if (day is null) return;

        try
        {
            if (useRecipe && newRecipeId is Guid rid)
            {
                await PlannerService.AddRecipeMealAsync(day.Id, newType, rid, newPortions);
                newRecipeId = null;
                newPortions = 1;
            }
            else if (!useRecipe && newFoodId is Guid fid)
            {
                await PlannerService.AddMealAsync(day.Id, newType, fid, newGrams);
                newFoodId = null;
                newGrams = 100;
            }

            errorMessage = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task Remove(Guid mealId)
    {
        await PlannerService.RemoveMealAsync(mealId);
        await LoadAsync();
    }

    private void GoBack() => Nav.NavigateTo("/");

    private static string ToSwedish(DayOfWeek d) => d switch
    {
        DayOfWeek.Monday => "Måndag",
        DayOfWeek.Tuesday => "Tisdag",
        DayOfWeek.Wednesday => "Onsdag",
        DayOfWeek.Thursday => "Torsdag",
        DayOfWeek.Friday => "Fredag",
        DayOfWeek.Saturday => "Lördag",
        _ => "Söndag"
    };

    private static string ToSwedish(MealType t) => t switch
    {
        MealType.Breakfast => "Frukost",
        MealType.Lunch => "Lunch",
        MealType.Snack => "Mellanmål",
        MealType.Dinner => "Middag",
        MealType.EveningMeal => "Kvällsmat",
        _ => "Fika"
    };
}