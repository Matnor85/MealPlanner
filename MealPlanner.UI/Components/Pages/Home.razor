@page "/"
@using System.Globalization
@using Application.Services
@using Domain.Entities

@inject WeeklyPlannerService PlannerService
@inject NavigationManager Nav

@if (isLoading)
{
    <p class="muted">Laddar...</p>
}
else if (errorMessage is not null)
{
    <div class="banner-error">@errorMessage</div>
}
else if (week is not null)
{
    <section class="week-header">
        <div class="week-nav">
            <button class="icon-btn" @onclick="() => ShiftWeek(-1)" aria-label="Föregående vecka">‹</button>
            <div>
                <div class="week-number">Vecka @week.WeekNumber</div>
                <div class="week-year">@week.Year</div>
            </div>
            <button class="icon-btn" @onclick="() => ShiftWeek(1)" aria-label="Nästa vecka">›</button>
        </div>

        <div class="week-total">
            <span class="big-number">@week.TotalWeeklyCalories</span>
            <span class="unit">kcal totalt</span>
            <span class="sub">snitt @(week.TotalWeeklyCalories / 7) kcal/dag</span>
        </div>
    </section>

    <section class="day-list">
        @foreach (var day in week.Days)
        {
            <button class="day-card" @onclick="() => OpenDay(day.SortOrder)">
                <div class="day-left">
                    <span class="day-name">@ToSwedish(day.Day)</span>
                    <span class="day-meals">
                        @(day.Meals.Count == 0 ? "Inget planerat" :
                          day.Meals.Count == 1 ? "1 måltid" : $"{day.Meals.Count} måltider")
                    </span>
                </div>
                <div class="day-right">
                    <span class="day-kcal">@day.TotalCalories</span>
                    <span class="unit-sm">kcal</span>
                </div>
            </button>
        }
    </section>

    <button class="btn-primary mt-20" @onclick="CopyToNext" disabled="@isWorking">
        Kopiera till nästa vecka
    </button>
}

@code {
    private WeeklyPlan? week;
    private bool isLoading = true;
    private bool isWorking;
    private string? errorMessage;

    private int year;
    private int weekNumber;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        year = ISOWeek.GetYear(today);
        weekNumber = ISOWeek.GetWeekOfYear(today);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            week = await PlannerService.GetOrCreateWeekAsync(year, weekNumber);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShiftWeek(int delta)
    {
        if (delta > 0)
        {
            if (weekNumber >= ISOWeek.GetWeeksInYear(year)) { weekNumber = 1; year++; }
            else weekNumber++;
        }
        else
        {
            if (weekNumber <= 1) { year--; weekNumber = ISOWeek.GetWeeksInYear(year); }
            else weekNumber--;
        }
        await LoadAsync();
    }

    private async Task CopyToNext()
    {
        if (week is null) return;
        isWorking = true;
        try
        {
            var copy = await PlannerService.CopyWeekToNextAsync(week.Year, week.WeekNumber);
            year = copy.Year;
            weekNumber = copy.WeekNumber;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isWorking = false;
        }
    }

    private void OpenDay(int sortOrder) => Nav.NavigateTo($"/day/{year}/{weekNumber}/{sortOrder}");

    private static string ToSwedish(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Måndag",
        DayOfWeek.Tuesday => "Tisdag",
        DayOfWeek.Wednesday => "Onsdag",
        DayOfWeek.Thursday => "Torsdag",
        DayOfWeek.Friday => "Fredag",
        DayOfWeek.Saturday => "Lördag",
        _ => "Söndag"
    };
}