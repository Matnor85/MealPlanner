@page "/"
@using System.Globalization
@using Application.Services
@using Domain.Entities

@inject WeeklyPlannerService PlannerService

<div class="container text-center mt-4">
    <h1>Matplaneraren</h1>

    @if (isLoading)
    {
        <p><em>Laddar schema...</em></p>
    }
    else if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (currentWeek != null)
    {
        <div class="card mt-4 shadow">
            <div class="card-body">
                <h2>Vecka @currentWeek.WeekNumber, @currentWeek.Year</h2>
                <p class="text-muted">Totalt: @currentWeek.TotalWeeklyCalories kcal</p>

                <button class="btn btn-primary mt-2" @onclick="GoToNextWeek">
                    Kopiera till nästa vecka
                </button>
            </div>
        </div>

        <div class="mt-4">
            @foreach (var day in currentWeek.Days)
            {
                <div class="card mb-2">
                    <div class="card-body d-flex justify-content-between">
                        <strong>@ToSwedish(day.Day)</strong>
                        <span>@day.TotalCalories kcal</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private WeeklyPlan? currentWeek;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Aktuell vecka i stället för hårdkodad 2026/32
            var today = DateTime.Today;
            currentWeek = await PlannerService.GetOrCreateWeekAsync(
                ISOWeek.GetYear(today),
                ISOWeek.GetWeekOfYear(today));
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte ladda veckan: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GoToNextWeek()
    {
        if (currentWeek is null) return;

        isLoading = true;
        try
        {
            currentWeek = await PlannerService.CopyWeekToNextAsync(
                currentWeek.Year, currentWeek.WeekNumber);
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte kopiera veckan: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string ToSwedish(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Måndag",
        DayOfWeek.Tuesday => "Tisdag",
        DayOfWeek.Wednesday => "Onsdag",
        DayOfWeek.Thursday => "Torsdag",
        DayOfWeek.Friday => "Fredag",
        DayOfWeek.Saturday => "Lördag",
        _ => "Söndag"
    };
}